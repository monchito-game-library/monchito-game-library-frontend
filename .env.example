# Connection string de Supabase para aplicar patches SQL desde local.
# Supabase Dashboard → Project Settings → Database → Connection string → URI (mode: Session).
# Reemplaza [YOUR-PASSWORD] por la password de la base de datos.
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
