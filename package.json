{
  "name": "monchito-game-library",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "build": "ng build",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --configuration=coverage",
    "test:eslint-rules": "node eslint-rules/no-inline-types-in-layer/index.spec.js && node eslint-rules/clean-architecture-boundaries/index.spec.js",
    "check:unused": "knip",
    "clean:install": "rm -rf node_modules && rm package-lock.json && npm i",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "vercel-build": "node scripts/set-env.js && ng build --configuration production",
    "lighthouse": "node --import tsx/esm scripts/lighthouse.mts",
    "db:apply": "node --env-file=.env scripts/db-apply.mjs"
  },
  "dependencies": {
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/animations": "21.2.11",
    "@angular/cdk": "21.2.9",
    "@angular/common": "21.2.11",
    "@angular/compiler": "21.2.11",
    "@angular/core": "21.2.11",
    "@angular/forms": "21.2.11",
    "@angular/localize": "21.2.11",
    "@angular/material": "21.2.9",
    "@angular/platform-browser": "21.2.11",
    "@angular/platform-browser-dynamic": "21.2.11",
    "@angular/router": "21.2.11",
    "@angular/service-worker": "21.2.11",
    "@jsverse/transloco": "8.3.0",
    "@sentry/angular": "10.51.0",
    "@supabase/supabase-js": "2.105.1",
    "@typescript-eslint/parser": "8.59.1",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.9",
    "@angular/build": "21.2.9",
    "@angular/cli": "21.2.9",
    "@angular/compiler-cli": "21.2.11",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "angular-eslint": "21.3.1",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "knip": "6.10.0",
    "lighthouse": "13.2.0",
    "lint-staged": "16.4.0",
    "pg": "8.20.0",
    "playwright": "1.59.1",
    "playwright-lighthouse": "4.0.0",
    "prettier": "3.8.3",
    "prettier-plugin-package": "2.0.0",
    "sass": "1.99.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  },
  "lint-staged": {
    "*.{ts,html,scss}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
