{
  "name": "monchito-game-library",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "npm": ">=10.9.2"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:coverage": "ng test --configuration=coverage",
    "clean:install": "rm -rf node_modules && rm package-lock.json && npm i",
    "lint": "eslint . --ext .ts,.html",
    "lint:fix": "eslint . --ext .ts,.html --fix",
    "lint:boundaries": "eslint src --ext .ts | grep \"clean-arch/boundaries\" -B2",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\"",
    "husky": "husky",
    "vercel-build": "node scripts/set-env.js && ng build --configuration production"
  },
  "dependencies": {
    "@angular-eslint/eslint-plugin": "21.3.0",
    "@angular-eslint/eslint-plugin-template": "21.3.0",
    "@angular-eslint/template-parser": "21.3.0",
    "@angular/animations": "21.2.3",
    "@angular/cdk": "21.2.2",
    "@angular/common": "21.2.3",
    "@angular/compiler": "21.2.3",
    "@angular/core": "21.2.3",
    "@angular/forms": "21.2.3",
    "@angular/localize": "21.2.3",
    "@angular/material": "21.2.2",
    "@angular/platform-browser": "21.2.3",
    "@angular/platform-browser-dynamic": "21.2.3",
    "@angular/router": "21.2.3",
    "@angular/service-worker": "21.2.3",
    "@jsverse/transloco": "8.2.1",
    "@supabase/supabase-js": "2.99.1",
    "@typescript-eslint/parser": "8.57.0",
    "dexie": "4.0.11",
    "ngx-image-cropper": "9.1.6",
    "rxjs": "7.8.0",
    "tslib": "2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.2",
    "@angular/build": "21.2.2",
    "@angular/cli": "21.2.2",
    "@angular/compiler-cli": "21.2.3",
    "@types/express": "4.17.17",
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "4.1.0",
    "angular-eslint": "21.3.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "61.7.1",
    "happy-dom": "20.8.4",
    "husky": "9.1.7",
    "lint-staged": "15.5.1",
    "prettier": "3.8.1",
    "prettier-plugin-package": "1.4.0",
    "sass": "1.87.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.{ts,html,scss}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
